# ════════════════════════════════════════════════════════════════════════
# Hisaflow LLM Gateway — Required Environment Variables
# Set ALL of these in Railway → Variables for the gateway service.
# ════════════════════════════════════════════════════════════════════════

# ── Security ─────────────────────────────────────────────────────────────
# A random secret that guards access to the LiteLLM proxy.
# Generate with: openssl rand -hex 32
# The NestJS backend uses this as its "API key" when calling the gateway.
LITELLM_MASTER_KEY=sk-hisaflow-change-me

# ── AI Provider Keys (Primary Pool) ──────────────────────────────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# ── AWS Bedrock (Tier 6 — add when ready) ────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── NestJS Backend Connection ─────────────────────────────────────────────
# Set this in the BACKEND Railway service (not here):
# LITELLM_BASE_URL=https://<your-gateway-service>.railway.app/v1
# LITELLM_MASTER_KEY=<same value as above>
