generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Organizations (Tenants) ─────────────────────────────────────

model Organization {
  id           String   @id @default(cuid())
  name         String
  businessType String   @map("business_type")
  currency     String   @default("KES")
  country      String   @default("KE")
  phone        String?
  inviteCode   String?  @unique @map("invite_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users                 OrgMembership[]
  inventoryItems        InventoryItem[]
  transactions          InventoryTransaction[]
  alerts                Alert[]
  businessTransactions  BusinessTransaction[]
  notes                 Note[]
  creditRecords         CreditRecord[]
  @@map("organizations")
}

// ── Users ───────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String?  @unique
  phone     String?  @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships        OrgMembership[]
  pushSubscriptions  PushSubscription[]
  notes              Note[]

  @@map("users")
}

// ── Org Membership (User <-> Organization with role) ────────────

enum OrgRole {
  OWNER
  MANAGER
  STAFF
}

model OrgMembership {
  id             String      @id @default(cuid())
  userId         String      @map("user_id")
  organizationId String      @map("organization_id")
  role           OrgRole     @default(STAFF)
  createdAt      DateTime    @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("org_memberships")
}

// ── Inventory Items ─────────────────────────────────────────────

enum StockStatus {
  HEALTHY
  LOW
  CRITICAL
  OUT_OF_STOCK
}

model InventoryItem {
  id               String      @id @default(cuid())
  organizationId   String      @map("organization_id")
  name             String
  category         String?
  unit             String      @default("units")
  quantity         Decimal     @default(0) @db.Decimal(12, 3)
  reorderThreshold Decimal?    @map("reorder_threshold") @db.Decimal(12, 3)
  costPrice        Decimal?    @map("cost_price") @db.Decimal(12, 2)
  sellingPrice     Decimal?    @map("selling_price") @db.Decimal(12, 2)
  status           StockStatus @default(HEALTHY)
  isActive         Boolean     @default(true) @map("is_active")
  
  // Business specific fields
  expiryDate       DateTime?   @map("expiry_date")
  serialNumber     String?     @map("serial_number")
  batchNumber      String?     @map("batch_number")

  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id])
  transactions InventoryTransaction[]
  alerts       Alert[]               // <-- added
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("inventory_items")
}

// ── Inventory Transactions (append-only ledger) ─────────────────

enum TransactionType {
  SALE
  PURCHASE
  ADJUSTMENT
  WASTAGE
  RETURN
  TRANSFER
}

model InventoryTransaction {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  itemId         String          @map("item_id")
  type           TransactionType
  quantityBefore Decimal         @map("quantity_before") @db.Decimal(12, 3)
  quantityChange Decimal         @map("quantity_change") @db.Decimal(12, 3)
  quantityAfter  Decimal         @map("quantity_after") @db.Decimal(12, 3)
  reason         String?
  actorId        String?         @map("actor_id")
  source         String          @default("web")
  
  // Business specific fields
  clientName     String?         @map("client_name")
  metadata       Json?

  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  item         InventoryItem @relation(fields: [itemId], references: [id])
  creditRecord CreditRecord?

  @@index([organizationId])
  @@index([organizationId, itemId])
  @@index([organizationId, createdAt])
  @@map("inventory_transactions")
}

// ── Alert Enums ─────────────────────────────────────────────────
enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  DEAD_STOCK
  EXPIRY_RISK
  VARIANCE
  DAILY_INSIGHT
  STAFF_ACTIVITY
}

enum AlertStatus {
  UNRESOLVED
  RESOLVED
  SNOOZED
}

// ── Alerts ───────────────────────────────────────────────────────
model Alert {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  itemId         String?       @map("item_id")
  type           AlertType
  severity       AlertSeverity
  status         AlertStatus   @default(UNRESOLVED)
  title          String
  description    String
  resolvedAt     DateTime?     @map("resolved_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  item          InventoryItem? @relation(fields: [itemId], references: [id])

  @@unique([organizationId, itemId, type], name: "organizationId_itemId_type")
  @@index([organizationId, status])
  @@map("alerts")
}

// ── Push Subscriptions ─────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_subscriptions")
}

// ── Business Transactions (Operating expenses & non-inventory income) ──────────

enum BusinessTxType {
  INCOME
  EXPENSE
}

model BusinessTransaction {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  type           BusinessTxType
  category       String         // RENT | SALARY | UTILITIES | LOAN | SUPPLIES | TRANSPORT | MARKETING | TAX | SERVICES | OTHER_EXPENSE | SERVICE_FEE | OTHER_INCOME
  amount         Decimal        @db.Decimal(12, 2)
  description    String?
  staffName      String?        @map("staff_name")   // for SALARY entries
  date           DateTime       @default(now())
  isRecurring    Boolean        @default(false)       @map("is_recurring")
  recurrenceRule String?        @map("recurrence_rule") // MONTHLY | WEEKLY | YEARLY
  createdAt      DateTime       @default(now())       @map("created_at")
  updatedAt      DateTime       @updatedAt            @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, date])
  @@index([organizationId, type])
  @@map("business_transactions")
}

// ── Notes & Scheduling ─────────────────────────────────────────────────────────

enum NoteImportance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NoteStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model Note {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  authorId       String         @map("author_id")
  title          String
  content        String?        @db.Text
  importance     NoteImportance @default(MEDIUM)
  status         NoteStatus     @default(OPEN)
  dueDate        DateTime?      @map("due_date")
  isPinned       Boolean        @default(false) @map("is_pinned")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id])
  author         User           @relation(fields: [authorId], references: [id])
  checklistItems ChecklistItem[]

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, importance])
  @@map("notes")
}

model ChecklistItem {
  id          String   @id @default(cuid())
  noteId      String   @map("note_id")
  text        String
  isCompleted Boolean  @default(false) @map("is_completed")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@map("checklist_items")
}

// ── Credit Management (Accounts Receivable) ────────────────────────────────────

enum CreditStatus {
  UNPAID
  PARTIAL
  PAID
}

model CreditRecord {
  id               String       @id @default(cuid())
  organizationId   String       @map("organization_id")
  clientName       String       @map("client_name")
  transactionId    String?      @unique @map("transaction_id")
  amountTotal      Decimal      @db.Decimal(12, 2)
  amountPaid       Decimal      @default(0) @db.Decimal(12, 2)
  dueDate          DateTime?    @map("due_date")
  status           CreditStatus @default(UNPAID)
  notes            String?      @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization     Organization @relation(fields: [organizationId], references: [id])
  transaction      InventoryTransaction? @relation(fields: [transactionId], references: [id])

  @@index([organizationId, status])
  @@map("credit_records")
}
